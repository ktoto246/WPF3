<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
      Title="СЛУЖБА КРОВИ — Главное окно" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnalyticsMenuButton" BasedOn="{StaticResource MenuButton}" TargetType="Button">
            <Setter Property="Foreground" Value="#34D399"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2937">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="15,20,15,20">
                    <TextBlock Text="ЦЕНТР ДОНОРСТВА" FontSize="18" FontWeight="Bold" Foreground="#EF4444" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <Border Background="#374151" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock x:Name="UserInfoText" Text="ФИО Сотрудника" Foreground="White" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,4"/>
                            <TextBlock x:Name="UserRoleText" Text="Роль" Foreground="#9CA3AF" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="10,0">
                    <TextBlock Text="ОСНОВНЫЕ РАЗДЕЛЫ" Foreground="#6B7280" FontSize="11" FontWeight="Bold" Margin="15,5,0,5"/>
                    <Button x:Name="BtnDonors" Content="Доноры" Style="{StaticResource MenuButton}" Visibility="Collapsed" Click="BtnDonors_Click"/>
                    <Button x:Name="BtnExams" Content="Мед. осмотры" Style="{StaticResource MenuButton}" Visibility="Collapsed" Click="BtnExams_Click"/>
                    <Button x:Name="BtnDonations" Content="Донации" Style="{StaticResource MenuButton}" Visibility="Collapsed" Click="BtnDonations_Click"/>
                    <Button x:Name="BtnLabTests" Content="Лаборатория" Style="{StaticResource MenuButton}" Visibility="Collapsed" Click="BtnLabTests_Click"/>
                    <Button x:Name="BtnComponents" Content="Склад компонентов" Style="{StaticResource MenuButton}" Visibility="Collapsed" Click="BtnComponents_Click"/>
                    <Button x:Name="BtnQuarantine" Content="Карантин плазмы" Style="{StaticResource MenuButton}" Visibility="Collapsed" Click="BtnQuarantine_Click"/>
                    <Button x:Name="BtnIssues" Content="Выдача и списание" Style="{StaticResource MenuButton}" Visibility="Collapsed" Click="BtnIssues_Click"/>
                    <Button x:Name="BtnRecipients" Content="Получатели крови" Style="{StaticResource MenuButton}" Visibility="Collapsed" Click="BtnRecipients_Click"/>
                    <Button x:Name="BtnEmployees" Content="Сотрудники системы" Style="{StaticResource MenuButton}" Visibility="Collapsed" Click="BtnEmployees_Click"/>
                    <Separator Margin="10,10,10,10" Background="#374151"/>
                    <Button x:Name="BtnReports" Content="Аналитика и отчёты" Style="{StaticResource AnalyticsMenuButton}" Visibility="Collapsed" Click="BtnReports_Click"/>
                </StackPanel>

                <Button Grid.Row="2" x:Name="BtnLogout" Content="🚪 Выйти из системы" Style="{StaticResource MenuButton}" Foreground="#FCA5A5" Margin="10,0,10,20" Click="BtnLogout_Click"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#F3F4F6">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>
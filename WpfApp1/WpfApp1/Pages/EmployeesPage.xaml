<Page x:Class="WpfApp1.Pages.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="900"
      Title="Учетные записи сотрудников" Loaded="Page_Loaded" Background="#F3F4F6">

    <Page.Resources>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryBtn" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,10,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Учетные записи сотрудников" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                <DataGrid x:Name="EmployeesGrid" Grid.Row="1" AutoGenerateColumns="False" 
                          IsReadOnly="True" SelectionChanged="EmployeesGrid_SelectionChanged"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="#E5E7EB" BorderThickness="0"
                          RowBackground="White" AlternatingRowBackground="#F9FAFB" 
                          RowHeight="40" Background="Transparent" Foreground="#374151"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#4B5563"/>
                            <Setter Property="Padding" Value="10,8"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" MinWidth="180" Width="*"/>
                        <DataGridTextColumn Header="Должность" Binding="{Binding Position}" MinWidth="140"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding Role}" MinWidth="100"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}" MinWidth="100"/>
                        <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" MinWidth="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="10,0,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock Text="Данные сотрудника" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                    <TextBlock Text="ФИО *" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtFullName" Style="{StaticResource ModernTextBox}"/>

                    <TextBlock Text="Должность *" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtPosition" Style="{StaticResource ModernTextBox}"/>

                    <TextBlock Text="Уровень доступа (Роль) *" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="CmbRole" Style="{StaticResource ModernComboBox}">
                        <ComboBoxItem Content="Регистратор"/>
                        <ComboBoxItem Content="Медсестра"/>
                        <ComboBoxItem Content="Врач"/>
                        <ComboBoxItem Content="Лаборант"/>
                        <ComboBoxItem Content="Заведующий"/>
                    </ComboBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Логин *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="TxtLogin" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Пароль *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="TxtPassword" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Email (ContactInfo)" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtContactInfo" Style="{StaticResource ModernTextBox}"/>

                    <Grid Margin="0,5,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnAdd" Grid.Column="0" Content="Добавить" Style="{StaticResource PrimaryBtn}" Click="BtnAdd_Click"/>
                        <Button x:Name="BtnSave" Grid.Column="2" Content="Сохранить" Style="{StaticResource ActionBtn}" Click="BtnSave_Click"/>
                        <Button x:Name="BtnToggleActive" Grid.Column="4" Content="Деактивировать" Style="{StaticResource ActionBtn}" Click="BtnToggleActive_Click"/>
                    </Grid>

                    <Separator Margin="0,0,0,15" Background="#E5E7EB"/>

                    <Button x:Name="BtnClear" Content="Очистить форму" Style="{StaticResource ActionBtn}" Margin="0,0,0,10" Click="BtnClear_Click"/>
                    <Button x:Name="BtnExport" Content="Экспорт в Excel" Style="{StaticResource PrimaryBtn}" Background="#10B981" Click="BtnExport_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
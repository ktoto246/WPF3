<Page x:Class="WpfApp1.Pages.PlasmaQuarantinePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1000"
      Title="Карантинизация плазмы" Loaded="Page_Loaded" Background="#F3F4F6">

    <Page.Resources>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryBtn" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,10,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Контроль карантинизации плазмы" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                <DataGrid x:Name="QuarantineGrid" Grid.Row="1" AutoGenerateColumns="False" 
                          IsReadOnly="True" SelectionChanged="QuarantineGrid_SelectionChanged"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="#E5E7EB" BorderThickness="0"
                          RowBackground="White" AlternatingRowBackground="#F9FAFB" 
                          RowHeight="40" Background="Transparent" Foreground="#374151"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#4B5563"/>
                            <Setter Property="Padding" Value="10,8"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="LOT партии" Binding="{Binding BloodComponent.LotNumber}" MinWidth="130"/>
                        <!-- Вот он, твой донор, сразу видно -->
                        <DataGridTextColumn Header="Донор" Binding="{Binding BloodComponent.Donation.Donor.FullName}" MinWidth="180" Width="*"/>
                        <DataGridTextColumn Header="Объем (мл)" Binding="{Binding BloodComponent.VolumeMl}" MinWidth="90"/>
                        <DataGridTextColumn Header="Начало карантина" Binding="{Binding StartDate, StringFormat=\{0:dd.MM.yyyy\}}" MinWidth="130"/>
                        <DataGridTextColumn Header="Плановый выход" Binding="{Binding PlannedReleaseDate, StringFormat=\{0:dd.MM.yyyy\}}" MinWidth="120"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" MinWidth="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="10,0,0,0" VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <StackPanel Margin="20">
                <TextBlock Text="Управление статусом" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                <TextBlock Text="Выбранная партия (LOT)" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="TxtSelectedLot" Style="{StaticResource ModernTextBox}" IsReadOnly="True"/>

                <TextBlock Text="Планируемый выход" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="TxtPlannedDate" Style="{StaticResource ModernTextBox}" IsReadOnly="True"/>

                <TextBlock Text="Повторная донация (Подтверждение) *" Style="{StaticResource FormLabel}"/>
                <ComboBox x:Name="CmbConfirmDonation" Style="{StaticResource ModernComboBox}" DisplayMemberPath="DonationNumber" SelectedValuePath="DonationId"/>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnRelease" Grid.Column="0" Content="Снять с карантина" Style="{StaticResource ActionBtn}" Background="#10B981" Foreground="White" Click="BtnRelease_Click"/>
                    <Button x:Name="BtnDispose" Grid.Column="2" Content="Утилизировать" Style="{StaticResource PrimaryBtn}" Click="BtnDispose_Click"/>
                </Grid>

                <Separator Margin="0,20,0,15" Background="#E5E7EB"/>

                <Button x:Name="BtnExport" Content="Экспорт отчета в Excel" Style="{StaticResource ActionBtn}" Click="BtnExport_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>